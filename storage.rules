rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isSimon() {
      return isSignedIn() && (
        request.auth.uid == 'Z8gkNLZEVUWbsooR8R7OuHxApB62' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2' ||
        request.auth.uid == 'zdf58EsGJKa2xr7D6RmNBS3gbx53' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'simon@pezeka.com')
      );
    }

    function isFinance() {
      return isSimon() || (
        isSignedIn() && (
          request.auth.token.email != null && request.auth.token.email.lower().matches('^.*@finance\\.pezeka\\.com$')
        )
      );
    }

    function isStaff() {
      return isSimon() || isFinance() || (
        isSignedIn() && (
          (request.auth.token.email != null && request.auth.token.email.lower().matches('^.*@staff\\.pezeka\\.com$')) ||
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['staff', 'finance']
        )
      );
    }

    // --- KYC Documents ---
    
    match /kyc/{customerId}/{allPaths=**} {
      allow read, create: if isStaff() || (isSignedIn() && request.auth.uid == customerId);
      allow update, delete: if isFinance();
    }

    // --- Global Bypass for Super Admin ---
    match /{allPaths=**} {
      allow read, write: if isSimon();
    }
  }
}
