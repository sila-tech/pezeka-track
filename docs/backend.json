{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer of Pezeka Credit Ltd.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "Full name of the customer."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the customer."
        },
        "email": {
          "type": "string",
          "description": "Email address of the customer.",
          "format": "email"
        },
        "joinDate": {
          "type": "string",
          "description": "Date the customer joined.",
          "format": "date"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL of the customer's avatar image."
        },
        "status": {
          "type": "string",
          "description": "The current status of the customer's account.",
          "enum": [
            "Active Loan",
            "Paid Off",
            "Overdue"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "phone",
        "email",
        "joinDate"
      ]
    },
    "Loan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Loan",
      "type": "object",
      "description": "Represents a loan disbursed to a customer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the loan."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to Customer."
        },
        "disbursementDate": {
          "type": "string",
          "description": "Date the loan was disbursed.",
          "format": "date-time"
        },
        "amount": {
          "type": "number",
          "description": "Amount disbursed to the customer."
        },
        "interestRate": {
          "type": "number",
          "description": "Interest rate for the loan."
        },
        "loanTerm": {
          "type": "number",
          "description": "Duration of the loan in months."
        },
        "repaymentSchedule": {
          "type": "string",
          "description": "Repayment schedule.",
          "enum": [
            "daily",
            "weekly",
            "monthly"
          ]
        },
        "status": {
          "type": "string",
          "description": "The current status of the loan.",
          "enum": [
            "active",
            "paid",
            "overdue"
          ]
        },
        "dueDate": {
          "type": "string",
          "description": "Date the next payment is due.",
          "format": "date"
        },
        "principal": {
          "type": "number"
        },
        "interest": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "customerId",
        "disbursementDate",
        "amount",
        "interestRate",
        "loanTerm",
        "repaymentSchedule",
        "status",
        "dueDate"
      ]
    },
    "Payment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Payment",
      "type": "object",
      "description": "Represents a payment made by a customer towards a loan.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the payment."
        },
        "loanId": {
          "type": "string",
          "description": "Reference to Loan."
        },
        "paymentDate": {
          "type": "string",
          "description": "Date the payment was made.",
          "format": "date-time"
        },
        "amountPaid": {
          "type": "number",
          "description": "Amount paid by the customer."
        }
      },
      "required": [
        "id",
        "loanId",
        "paymentDate",
        "amountPaid"
      ]
    },
    "FinancialRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FinancialRecord",
      "type": "object",
      "description": "Represents a financial record of daily expenses, payouts, or receipts.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the financial record."
        },
        "date": {
          "type": "string",
          "description": "Date of the financial record.",
          "format": "date-time"
        },
        "amount": {
          "type": "number"
        },
        "type": {
          "type": "string",
          "enum": [
            "expense",
            "payout",
            "receipt"
          ]
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "date",
        "amount",
        "type",
        "description",
        "category"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": {
            "$ref": "#/backend/entities/Customer"
          },
          "description": "Stores customer data."
        }
      },
      {
        "path": "/loans/{loanId}",
        "definition": {
          "entityName": "Loan",
          "schema": {
            "$ref": "#/backend/entities/Loan"
          },
          "description": "Stores loan data."
        }
      },
      {
        "path": "/financialRecords/{financialRecordId}",
        "definition": {
          "entityName": "FinancialRecord",
          "schema": {
            "$ref": "#/backend/entities/FinancialRecord"
          },
          "description": "Stores financial records."
        }
      }
    ]
  }
}