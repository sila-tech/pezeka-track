
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and role for staff and finance users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["staff", "finance"] },
        "name": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Represents a customer of Pezeka Credit Ltd.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "idNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Represents a loan disbursed to a customer.",
      "type": "object",
      "properties": {
        "loanNumber": { "type": "string", "description": "Unique identifier for the loan." },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "idNumber": { "type": "string", "description": "Customer's national ID number, from application." },
        "loanType": { "type": "string", "description": "The type of loan applied for." },
        "disbursementDate": { "type": "string", "format": "date-time" },
        "principalAmount": { "type": "number", "description": "The initial amount of the loan."},
        "interestRate": { "type": "number", "description": "The monthly interest rate for the loan in percentage." },
        "registrationFee": { "type": "number", "default": 0 },
        "processingFee": { "type": "number", "default": 0 },
        "carTrackInstallationFee": { "type": "number", "default": 0 },
        "chargingCost": { "type": "number", "default": 0 },
        "numberOfInstalments": { "type": "number" },
        "instalmentAmount": { "type": "number" },
        "totalRepayableAmount": { "type": "number", "description": "Total amount to be paid back."},
        "totalPaid": { "type": "number", "default": 0 },
        "totalPenalties": { "type": "number", "default": 0, "description": "Total amount of penalties applied to the loan." },
        "paymentFrequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "status": { "type": "string", "enum": ["due", "paid", "active", "rollover", "overdue", "application", "rejected"] },
        "disbursementRecorded": { "type": "boolean", "default": false, "description": "Whether disbursement payout and upfront fees have been recorded in finance." },
        "payments": {
            "type": "array",
            "description": "History of payments made for this loan.",
            "items": {
                "type": "object",
                "properties": {
                    "paymentId": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "amount": { "type": "number" }
                },
                "required": ["paymentId", "date", "amount"]
            }
        },
        "penalties": {
            "type": "array",
            "description": "History of penalties applied to this loan.",
            "items": {
                "type": "object",
                "properties": {
                    "penaltyId": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "amount": { "type": "number" },
                    "description": { "type": "string" }
                },
                "required": ["penaltyId", "date", "amount", "description"]
            }
        },
        "comments": { "type": "string", "description": "General comments about the loan, such as rollover requests." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "loanNumber",
        "customerId", 
        "customerName", 
        "customerPhone",
        "disbursementDate", 
        "principalAmount",
        "interestRate",
        "numberOfInstalments",
        "instalmentAmount",
        "totalRepayableAmount",
        "paymentFrequency", 
        "status"
      ]
    },
    "FinanceEntry": {
      "title": "Finance Entry",
      "description": "Represents a financial transaction.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["expense", "payout", "receipt"] },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "loanId": { "type": "string", "description": "The ID of the associated loan, if applicable." },
        "expenseCategory": {
          "type": "string",
          "enum": ["facilitation_commission", "office_purchase", "other"],
          "description": "Category for an expense entry."
        },
        "receiptCategory": {
          "type": "string",
          "enum": ["loan_repayment", "upfront_fees", "investment", "other"],
          "description": "Category for a receipt entry."
        },
        "payoutCategory": {
          "type": "string",
          "enum": ["loan_disbursement", "investor_withdrawal", "other"],
          "description": "Category for a payout entry."
        }
      },
      "required": ["type", "date", "amount"]
    },
    "Investor": {
      "title": "Investor",
      "description": "Represents an investor's portfolio.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "totalInvestment": { "type": "number" },
        "currentBalance": { "type": "number" },
        "interestRate": { "type": "number", "description": "The monthly interest rate as a percentage (e.g., 5 for 5%)." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "interestEntries": {
            "type": "array",
            "description": "History of interest payments added to this portfolio.",
            "items": {
                "type": "object",
                "properties": {
                    "entryId": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "amount": { "type": "number" },
                    "description": { "type": "string" }
                },
                "required": ["entryId", "date", "amount"]
            }
        },
        "withdrawals": {
            "type": "array",
            "description": "History of withdrawal requests.",
            "items": {
                "type": "object",
                "properties": {
                    "withdrawalId": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "amount": { "type": "number" },
                    "status": { "type": "string", "enum": ["pending", "processed", "rejected"] }
                },
                "required": ["withdrawalId", "date", "amount", "status"]
            }
        },
        "deposits": {
            "type": "array",
            "description": "History of deposits made into this portfolio.",
            "items": {
                "type": "object",
                "properties": {
                    "depositId": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "amount": { "type": "number" },
                    "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
                },
                "required": ["depositId", "date", "amount", "status"]
            }
        }
      },
      "required": ["uid", "name", "email", "totalInvestment", "currentBalance"]
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Stores all customer records."
    },
    "/loans/{loanId}": {
      "schema": { "$ref": "#/entities/Loan" },
      "description": "Stores all loan records."
    },
    "/financeEntries/{entryId}": {
      "schema": { "$ref": "#/entities/FinanceEntry" },
      "description": "Stores all financial entries."
    },
    "/investors/{investorId}": {
      "schema": { "$ref": "#/entities/Investor" },
      "description": "Stores investor portfolio data. The document ID must be the user's UID."
    }
  }
}
