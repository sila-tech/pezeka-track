
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and role for staff and finance users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["staff", "finance"] },
        "name": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Represents a customer of Pezeka Credit Ltd.",
      "type": "object",
      "properties": {
        "accountNumber": { "type": "string", "description": "Unique account number for the customer." },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "idNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Represents a loan disbursed to a customer.",
      "type": "object",
      "properties": {
        "loanNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "due", "overdue", "paid", "rollover", "application", "rejected"] },
        "principalAmount": { "type": "number" },
        "interestRate": { "type": "number" },
        "totalRepayableAmount": { "type": "number" },
        "totalPaid": { "type": "number", "default": 0 },
        "totalPenalties": { "type": "number", "default": 0 }
      }
    },
    "MailLog": {
      "title": "Mail Log",
      "description": "Records of emails sent by the system or staff.",
      "type": "object",
      "properties": {
        "recipient": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "sender": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles."
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Stores all customer records."
    },
    "/loans/{loanId}": {
      "schema": { "$ref": "#/entities/Loan" },
      "description": "Stores all loan records."
    },
    "/loan_applications/{appId}": {
      "schema": { "$ref": "#/entities/Loan" },
      "description": "Mirror of loans for temporary application processing."
    },
    "/financeEntries/{entryId}": {
      "description": "Stores all financial entries."
    },
    "/mail_logs/{logId}": {
      "schema": { "$ref": "#/entities/MailLog" },
      "description": "Logs of sent emails."
    },
    "/system_config/{configId}": {
      "description": "General application configuration and metadata."
    }
  }
}
