
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an internal staff member of Pezeka Credit Ltd.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "firstName", "lastName", "role", "email", "createdAt"]
    },
    "StaffGoal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StaffGoal",
      "type": "object",
      "description": "Monthly performance targets set for a staff member by Finance.",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "month": { "type": "string", "description": "Format: YYYY-MM" },
        "onboardingTarget": { "type": "number" },
        "disbursementTarget": { "type": "number" },
        "collectionTarget": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["staffId", "month", "onboardingTarget", "disbursementTarget", "collectionTarget"]
    },
    "ExpenseRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExpenseRequest",
      "type": "object",
      "description": "Represents a request for facilitation fees made by a staff member.",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["facilitation", "other"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approverId": { "type": "string" },
        "approverName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["staffId", "amount", "status", "createdAt"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Stores detailed information about a customer.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "nationalIdNumber": { "type": "string" },
        "contactNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "dateRegistered": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "nationalIdNumber", "contactNumber", "dateRegistered"]
    },
    "Loan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Loan",
      "type": "object",
      "description": "Records details of an individual loan.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "amountDisbursed": { "type": "number" },
        "disbursementDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "customerId", "amountDisbursed", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores internal staff member profiles."
        }
      },
      {
        "path": "/staffGoals/{goalId}",
        "definition": {
          "entityName": "StaffGoal",
          "schema": { "$ref": "#/backend/entities/StaffGoal" },
          "description": "Stores performance targets for staff."
        }
      },
      {
        "path": "/expenseRequests/{requestId}",
        "definition": {
          "entityName": "ExpenseRequest",
          "schema": { "$ref": "#/backend/entities/ExpenseRequest" },
          "description": "Stores staff requests for facilitation fees."
        }
      },
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": { "$ref": "#/backend/entities/Customer" },
          "description": "Stores customer profiles."
        }
      },
      {
        "path": "/loans/{loanId}",
        "definition": {
          "entityName": "Loan",
          "schema": { "$ref": "#/backend/entities/Loan" },
          "description": "Stores loan records."
        }
      },
      {
        "path": "/financeEntries/{entryId}",
        "definition": {
          "entityName": "FinanceEntry",
          "schema": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "amount": { "type": "number" },
              "date": { "type": "string" }
            }
          },
          "description": "General financial ledger."
        }
      }
    ]
  }
}
