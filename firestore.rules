rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only Simon can read or write any document in the database.
    function isSimon() {
      return request.auth != null && request.auth.token.email == 'simon@pezeka.com';
    }

    match /{document=**} {
      allow read, write: if isSimon();
    }
  }
}
