rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isFinanceUser() {
      return request.auth != null && (
        request.auth.token.email == 'simon@pezeka.com' ||
        request.auth.token.email.matches('.*@finance\\.pezeka\\.com$')
      );
    }

    function isStaffUser() {
      return request.auth != null && request.auth.token.email.matches('.*@staff\\.pezeka\\.com$');
    }
    
    function isStaffOrFinance() {
        return isStaffUser() || isFinanceUser();
    }

    function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isStaffOrFinance() || isOwner(userId);
    }

    match /customers/{customerId} {
      allow read, write: if isStaffOrFinance();
    }

    match /loans/{loanId} {
      allow get: if isStaffOrFinance() || isOwner(resource.data.customerId);
      allow list: if isStaffOrFinance() || 
                     (request.query.where.customerId != null && request.query.where.customerId == request.auth.uid);
      allow create: if isStaffOrFinance() ||
                       (isOwner(request.resource.data.customerId) && request.resource.data.status == 'application');
      allow update, delete: if isStaffOrFinance();
    }

    match /financeEntries/{entryId} {
      allow get, list: if isStaffOrFinance();
      allow create: if isFinanceUser() || (isStaffUser() && request.resource.data.type == 'receipt');
      allow update: if (isFinanceUser() || (isStaffUser() && resource.data.type == 'receipt')) && request.resource.data.type == resource.data.type;
      allow delete: if isFinanceUser() || (isStaffUser() && resource.data.type == 'receipt');
    }
  }
}
