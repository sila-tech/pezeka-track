rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles by looking up their profile
    function isSuperAdmin() {
      return request.auth.token.email == 'simon@pezeka.com';
    }

    function getUserRole() {
      // A user's role is stored in their profile document in the 'users' collection.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for User Profiles
    match /users/{userId} {
      // Admins can list all users and write to any user profile.
      allow list, write: if isStaff() || isFinance() || isSuperAdmin();
      // Any user can read their own profile (for role checking), and admins can read any profile.
      allow get: if isOwner(userId) || isStaff() || isFinance() || isSuperAdmin();
    }

    // Rules for Customers collection
    match /customers/{customerId} {
      // Only Staff, Finance, or SuperAdmins can read or write to the customers collection.
      allow read, write: if isStaff() || isFinance() || isSuperAdmin();
    }

    // Rules for Loans
    match /loans/{loanId} {
      // Staff, Finance, or SuperAdmins have full write access.
      allow write: if isStaff() || isFinance() || isSuperAdmin();
      
      // Staff, Finance, or SuperAdmins have full read access (get and list).
      allow read: if isStaff() || isFinance() || isSuperAdmin();
      
      // CUSTOMER-specific rules (for non-admins)
      // Customers can GET their own single loan document.
      allow get: if request.auth.uid == resource.data.customerId;
      
      // Customers can LIST loans. The client-side query must be properly filtered.
      allow list: if request.auth != null;
      
      // Customers can CREATE new loan applications for themselves.
      allow create: if request.auth.uid == request.resource.data.customerId && request.resource.data.status == 'application';
    }
    
    // Rules for Finance Entries
    match /financeEntries/{entryId} {
      // Only Finance users and the Super Admin can read or write finance entries.
      allow read, write: if isFinance() || isSuperAdmin();
    }

    // Rules for Investors
    match /investors/{investorId} {
      // Admins have full access.
      allow read, write: if isStaff() || isFinance() || isSuperAdmin();
      // Investor can read their own profile.
      allow get: if isOwner(investorId);
      // An investor can create their own profile during signup.
      allow create: if request.auth.uid == request.resource.data.uid;
    }
    
    // Rules for Investments
    match /investments/{investmentId} {
      // Admins have full access.
      allow read, write: if isStaff() || isFinance() || isSuperAdmin();
      // An investor can read their own investments.
      allow get: if request.auth.uid == resource.data.investorId;
      allow list: if request.auth != null; // Client query must filter by investorId
    }
  }
}
