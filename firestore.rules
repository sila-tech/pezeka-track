rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isFinanceUser() {
      return request.auth != null && (
        request.auth.token.email == 'simon@pezeka.com' ||
        request.auth.token.email.matches('.*@finance\\.pezeka\\.com$')
      );
    }

    function isStaffUser() {
      return request.auth != null && request.auth.token.email.matches('.*@staff\\.pezeka\\.com$');
    }

    function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isFinanceUser() || isOwner(userId);
    }

    // Customers
    match /customers/{customerId} {
      allow read, write: if isFinanceUser() || isStaffUser();
    }

    // Loans
    match /loans/{loanId} {
      allow read, write: if isFinanceUser() || isStaffUser();
    }

    // Finance Entries
    match /financeEntries/{entryId} {
      allow read: if isFinanceUser() || isStaffUser();

      // Create: Finance can create any type. Staff can only create receipts.
      allow create: if isFinanceUser() || 
                       (isStaffUser() && request.resource.data.type == 'receipt');

      // Update: Finance can update any type. Staff can only update receipts.
      // Don't allow changing the 'type' field on update.
      allow update: if (isFinanceUser() || (isStaffUser() && resource.data.type == 'receipt')) &&
                        request.resource.data.type == resource.data.type;
      
      // Delete: Finance can delete any type. Staff can only delete receipts.
      allow delete: if isFinanceUser() || (isStaffUser() && resource.data.type == 'receipt');
    }
  }
}
