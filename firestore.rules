rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('email', '').lower() == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Safely check for a specific role in the user's profile document
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Simon, Finance, and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document (Customer UID)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only Simon, Finance, or the Owner can modify profiles
      allow write: if isSuperAdmin() || isFinance() || isOwner(userId);
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isStaff();
      // Staff can create (register) but NOT update or delete
      allow create: if isStaff();
      // Only Finance/Admin can edit or delete customers
      allow update, delete: if isFinance();
    }

    // Loans
    match /loans/{loanId} {
      // Read: Staff/Finance see all. Customers see only their own.
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      
      // Create: Only Finance/Admin can add loan records. 
      // Authenticated customers can create applications (status is checked in UI logic)
      allow create: if isFinance() || (isAuthenticated() && request.resource.data.status == 'application');
      
      // Update: Finance manages all. Staff can ONLY add followUpNotes.
      allow update: if isFinance() || (
        isStaff() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followUpNotes', 'updatedAt'])
      );

      // Delete: Strictly Finance/Admin
      allow delete: if isFinance();
    }

    // Finance Entries (Sensitive Ledger)
    match /financeEntries/{entryId} {
      allow read, write: if isFinance();
    }

    // Investors
    match /investors/{investorId} {
      allow read: if isFinance() || isOwner(investorId);
      allow write: if isFinance();
    }
  }
}