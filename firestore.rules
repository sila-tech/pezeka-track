
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles by looking up their profile
    function isSuperAdmin() {
      return request.auth.token.email == 'simon@pezeka.com';
    }

    function getUserRole() {
      // A user's role is stored in their profile document in the 'users' collection.
      // This now safely returns an empty string if the document doesn't exist.
      if (exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      return '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for User Profiles
    match /users/{userId} {
      allow get: if isSuperAdmin() || isOwner(userId);
      allow list, write: if isSuperAdmin();
    }

    // Rules for Customers collection
    match /customers/{customerId} {
      allow read, write: if isSuperAdmin() || isStaff() || isFinance();
    }

    // Rules for Loans
    match /loans/{loanId} {
      allow read: if isSuperAdmin() || isStaff() || isFinance();
      allow write: if isSuperAdmin() || isStaff() || isFinance();
      
      // CUSTOMER-specific rules
      allow get: if request.auth.uid == resource.data.customerId;
      allow create: if request.auth.uid == request.resource.data.customerId && request.resource.data.status == 'application';
    }
    
    // Rules for Finance Entries
    match /financeEntries/{entryId} {
      allow read, write: if isSuperAdmin() || isFinance();
    }

    // Rules for Investors
    match /investors/{investorId} {
      // Broad read rule to allow LIST operations without document lookups
      allow list, get: if request.auth != null;

      // Strict write rules that CAN use document lookups
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isFinance();
    }

  }
}
