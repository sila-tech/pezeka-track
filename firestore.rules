rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2' // Simon's UID for redundancy
      );
    }

    // Safely get the user's role without triggering recursion
    function getUserRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /users/{userId} {
      // isOwner check must come first to prevent recursive role lookup
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /customers/{customerId} {
      allow list, get: if isStaff() || isFinance() || isSuperAdmin();
      allow write: if isStaff() || isFinance() || isSuperAdmin();
    }

    match /loans/{loanId} {
      allow list: if isStaff() || isFinance() || isSuperAdmin();
      allow get: if isStaff() || isFinance() || isSuperAdmin() || (request.auth != null && resource.data.customerId == request.auth.uid);
      allow write: if isStaff() || isFinance() || isSuperAdmin();
      allow create: if request.auth != null && (request.resource.data.customerId == request.auth.uid || isStaff() || isFinance() || isSuperAdmin());
    }
    
    match /financeEntries/{entryId} {
      allow list, get, create, update, delete: if isFinance() || isSuperAdmin();
    }

    match /investors/{investorId} {
      allow list: if isFinance() || isSuperAdmin();
      allow get: if isOwner(investorId) || isFinance() || isSuperAdmin();
      allow update: if (isOwner(investorId) && 
                    (
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['withdrawals', 'updatedAt']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deposits', 'updatedAt'])
                    )) || isFinance() || isSuperAdmin();
      allow create, delete: if isSuperAdmin() || isFinance();
    }
  }
}