rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSuperAdmin() {
      return request.auth.token.email == 'simon@pezeka.com';
    }

    function getUserRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /users/{userId} {
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
      allow get: if isOwner(userId) || isStaff() || isFinance() || isSuperAdmin();
    }

    match /customers/{customerId} {
      allow list: if isFinance() || isSuperAdmin();
      allow get: if isFinance() || isSuperAdmin();
      // STAFF RESTRICTION: Removed write access for staff
      allow write: if isFinance() || isSuperAdmin();
    }

    match /loans/{loanId} {
      allow list: if isFinance() || isSuperAdmin();
      allow get: if isFinance() || isSuperAdmin() || (request.auth != null && resource.data.customerId == request.auth.uid);
      // STAFF RESTRICTION: Removed write access for staff
      allow write: if isFinance() || isSuperAdmin();
      allow create: if request.auth != null && request.resource.data.customerId == request.auth.uid && request.resource.data.status == 'application';
    }
    
    match /financeEntries/{entryId} {
      allow list: if isFinance() || isSuperAdmin();
      allow get, write: if isFinance() || isSuperAdmin();
    }

    match /investors/{investorId} {
      allow list: if isFinance() || isSuperAdmin();
      allow get: if isOwner(investorId) || isFinance() || isSuperAdmin();
      allow update: if (isOwner(investorId) && 
                    (
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['withdrawals', 'updatedAt']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deposits', 'updatedAt'])
                    )) || isFinance() || isSuperAdmin();
      allow create, delete: if isSuperAdmin() || isFinance();
    }
  }
}
