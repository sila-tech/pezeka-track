rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('email', '').lower() == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Safely check for a specific role in the user's profile document
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Finance and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // User Profiles (Admin Staff/Finance)
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only Super Admin can manage system user profiles
      allow write: if isSuperAdmin();
    }

    // Customers
    match /customers/{customerId} {
      // Owners can read their own profile. Staff/Finance see all.
      allow read: if isStaff() || isOwner(customerId);
      // Staff can register new customers. Owners can create their profile on signup.
      allow create: if isStaff() || isOwner(customerId);
      // Only Finance/Admin or the Owner can update info (Staff cannot edit)
      allow update: if isFinance() || isOwner(customerId);
      // Strictly Finance/Admin deletion
      allow delete: if isFinance();
    }

    // Loans
    match /loans/{loanId} {
      // Read: Staff/Finance see all. Customers see only their own.
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      
      // Create: Only Finance/Admin can add direct active records. 
      // Customers/Staff can only create 'application' status loans for themselves.
      allow create: if isFinance() || (
        isAuthenticated() && 
        request.resource.data.status == 'application' &&
        request.resource.data.customerId == request.auth.uid
      );
      
      // Update: Finance manages all. Staff can ONLY add followUpNotes.
      allow update: if isFinance() || (
        isStaff() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followUpNotes', 'updatedAt'])
      );

      // Delete: Strictly Finance/Admin
      allow delete: if isFinance();
    }

    // Finance Entries (Sensitive Ledger)
    match /financeEntries/{entryId} {
      allow read, write: if isFinance();
    }

    // Investors
    match /investors/{investorId} {
      allow read: if isFinance() || isOwner(investorId);
      allow write: if isFinance();
    }
  }
}
