rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a Role-Based Access Control (RBAC) model.
     * We prioritize domain-based authorization for Pezeka staff to ensure 
     * immediate access even if the database profile is still synchronizing.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Robust check for Finance authorization. 
     * Prioritizes direct email matches and the @finance domain.
     */
    function isFinance() {
      let email = request.auth.token.email;
      let isSimon = email == 'simon@pezeka.com' || email == 'simon@finance.pezeka.com';
      let isFinanceDomain = email != null && email.endsWith('@finance.pezeka.com');
      let isFinanceUid = request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2';
      
      // Check Firestore doc only if domain check fails
      let hasFinanceRole = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'finance';
      
      return isSignedIn() && (isSimon || isFinanceDomain || isFinanceUid || hasFinanceRole);
    }

    /** 
     * @description Robust check for Staff authorization. 
     * Includes everyone in Finance plus the @staff domain.
     */
    function isStaff() {
      let email = request.auth.token.email;
      let isStaffDomain = email != null && (email.endsWith('@staff.pezeka.com') || email.endsWith('@finance.pezeka.com'));
      let isSimon = email == 'simon@pezeka.com';
      
      // Check Firestore doc only if domain check fails
      let hasStaffRole = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() in ['staff', 'finance'];
      
      return isSignedIn() && (isSimon || isStaffDomain || hasStaffRole);
    }

    /** @description Checks if the user is the owner of the document based on UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Staff profile management.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isFinance();
      allow delete: if isFinance();
    }

    /**
     * @description Customer records. Accessible to all internal staff.
     */
    match /customers/{customerId} {
      allow get, list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isSignedIn();
      allow update: if isStaff() || isOwner(customerId);
      allow delete: if isFinance();
    }

    /**
     * @description Loan records nested under customers.
     */
    match /customers/{customerId}/loans/{loanId} {
      allow get, list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isOwner(customerId);
      allow update: if isStaff();
      allow delete: if isFinance();

      match /repayments/{repaymentId} {
        allow get, list: if isStaff() || isOwner(customerId);
        allow create: if isStaff();
        allow update: if isStaff();
        allow delete: if isFinance();
      }
    }

    /**
     * @description Top level loans collection for aggregate queries.
     */
    match /loans/{loanId} {
      allow get, list: if isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isStaff() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isFinance();
    }

    /**
     * @description KYC Document Repository. 
     * STRICTLY STAFF ONLY. Customers cannot view their documents.
     */
    match /kyc_documents/{docId} {
      allow create: if isStaff();
      allow get, list: if isStaff();
      allow update, delete: if isFinance();
    }

    /**
     * @description Financial collections strictly restricted to finance staff.
     */
    match /dailyExpenses/{expenseId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyPayouts/{payoutId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyReceipts/{receiptId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /financeEntries/{entryId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /investors/{investorId} {
      allow get: if isSignedIn() && (request.auth.uid == investorId || isFinance());
      allow list, create, update, delete: if isFinance();
    }

    match /mail_logs/{logId} {
      allow get, list, create: if isFinance();
      allow update, delete: if false;
    }
  }
}