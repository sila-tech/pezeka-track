rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Check if the user has a specific role in their profile
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Simon, Finance, and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isFinance();
    }

    // Customers
    match /customers/{customerId} {
      // Customers can manage their own profile; Staff/Finance can manage all customers
      allow read, write: if isOwner(customerId) || isStaff();
    }

    // Loans
    match /loans/{loanId} {
      // Read: Staff/Finance see all. Customers see only their own loans.
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      
      // Create: Allowed for any authenticated user (to support applications from App and Web)
      allow create: if isAuthenticated();
      
      // Update/Delete: Staff/Finance manage all. Customers can only update their own applications.
      allow update, delete: if isStaff() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
    }

    // Finance Entries
    match /financeEntries/{entryId} {
      // ONLY Super Admin and Finance users can access or edit the financial ledger
      allow read, write: if isFinance();
    }

    // Investors
    match /investors/{investorId} {
      // Investors can manage their own portfolios; Finance users manage all
      allow read, write: if isOwner(investorId) || isFinance();
    }
  }
}