rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    // Checks if a user is signed in. This is the first step for any access.
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Securely checks if the signed-in user is Simon.
     * This uses the user's email from their login token because it is a unique
     * and secure identifier. Security rules cannot use a password or a plain
     * username for this check.
     */
    function isSimon() {
      return isSignedIn() && request.auth.token.email == 'simon@pezeka.com';
    }
    
    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * All collections are only accessible by Simon.
     * This rule applies to every document in the database, ensuring only
     * Simon has read and write permissions.
     */
    match /{document=**} {
      allow read, write: if isSimon();
    }
  }
}
