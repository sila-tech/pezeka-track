rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Authenticated user check.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that a document exists for update/delete operations.
     */
    function isExisting() {
      return resource != null;
    }

    /**
     * Role check for 'finance' or 'admin'. These users log in with a @finance.com email.
     */
    function isFinanceAdmin() {
      return isSignedIn() && request.auth.token.email != null && request.auth.token.email.matches('.*@finance\\.com$');
    }
    
    /**
     * Role check for 'staff'. A staff member is any authenticated user who is not a finance admin.
     * This includes anonymous users for the staff portal.
     */
    function isStaff() {
      return isSignedIn() && !isFinanceAdmin();
    }
    
    /**
     * On create, ensures the document's internal ID matches the path ID.
     */
    function hasValidId(docId) {
      return request.resource.data.id == docId;
    }
    
    /**
     * On update, ensures the internal ID is immutable.
     */
    function hasImmutableId() {
      return request.resource.data.id == resource.data.id;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description User documents are no longer used for authorization.
     * Access is locked down.
     */
    match /users/{userId} {
      allow read, write: if false;
    }

    /**
     * @description Manages access to customer information. Staff and admins can read.
     * Only admins can create, update, or delete.
     */
    match /customers/{customerId} {
      allow get, list: if isStaff() || isFinanceAdmin();
      allow create: if isFinanceAdmin() && hasValidId(customerId);
      allow update: if isFinanceAdmin() && isExisting() && hasImmutableId();
      allow delete: if isFinanceAdmin() && isExisting();
    }

    /**
     * @description Manages access to loans. Staff and admins can read.
     * Only admins can create, update, or delete.
     */
    match /loans/{loanId} {
      allow get, list: if isStaff() || isFinanceAdmin();
      allow create: if isFinanceAdmin();
      allow update: if isFinanceAdmin() && isExisting();
      allow delete: if isFinanceAdmin() && isExisting();

      /**
       * @description Manages access to loan payments. Permissions are inherited.
       */
      match /payments/{paymentId} {
        allow get, list: if isStaff() || isFinanceAdmin();
        allow create: if isFinanceAdmin();
        allow update: if isFinanceAdmin() && isExisting();
        allow delete: if isFinanceAdmin() && isExisting();
      }
    }

    /**
     * @description Controls access to sensitive financial records. Only finance admins can access.
     */
    match /financialRecords/{financialRecordId} {
      allow read, write: if isFinanceAdmin();
    }
  }
}
