
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    function isSuperAdmin() {
      // Super admin is defined by a specific email in the auth token.
      return request.auth.token.email == 'simon@pezeka.com';
    }

    // WARNING: The following functions use `get()` and CANNOT be used in `list` rules.
    // They are safe for single document access (`get`, `create`, `update`, `delete`).
    function getUserRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // Rules for User Profiles
    match /users/{userId} {
      // ONLY the super admin can list all user profiles.
      allow list: if isSuperAdmin();
      
      // Super admin can write/delete user profiles.
      allow write: if isSuperAdmin();

      // An admin can get any user's profile. A user can get their own profile.
      allow get: if isOwner(userId) || isStaff() || isFinance() || isSuperAdmin();
    }

    // Rules for Customers collection
    match /customers/{customerId} {
      // Any authenticated admin user can list customers. The UI controls visibility.
      // This rule is broad to prevent query errors. UI must enforce roles.
      allow list: if request.auth != null;
      
      // Only authorized roles can get a single customer document or write data.
      allow get, write: if isStaff() || isFinance() || isSuperAdmin();
    }

    // Rules for Loans
    match /loans/{loanId} {
      // Any authenticated user can list loans. The UI filters what is shown.
      allow list: if request.auth != null;
      
      // An admin can get any single loan document.
      allow get: if isStaff() || isFinance() || isSuperAdmin();
      
      // A customer can get their own loan document.
      allow get: if request.auth != null && resource.data.customerId == request.auth.uid;
      
      // Admins have full write access.
      allow write: if isStaff() || isFinance() || isSuperAdmin();
      
      // Customers can create new loan applications for themselves.
      allow create: if request.auth != null && request.resource.data.customerId == request.auth.uid && request.resource.data.status == 'application';
    }
    
    // Rules for Finance Entries
    match /financeEntries/{entryId} {
      // Any authenticated admin user can list finance entries. UI controls visibility.
      allow list: if request.auth != null;
      // Only Finance and Super Admin can get single entries or write.
      allow get, write: if isFinance() || isSuperAdmin();
    }

    // Rules for the Investors collection
    match /investors/{investorId} {
      // Any authenticated admin user can list investors. The UI controls visibility.
      allow list: if request.auth != null;
      
      // An investor can read their own portfolio data
      allow get: if isOwner(investorId);

      // Finance, or SuperAdmins have read access to individual documents.
      allow get: if isFinance() || isSuperAdmin();
      
      // An investor can update their own document to request a withdrawal.
      // We check that only the 'withdrawals' array is being modified.
      allow update: if isOwner(investorId) 
                    && request.resource.data.keys().hasOnly(['withdrawals', 'updatedAt']);

      // Only Finance and Super Admin can update portfolios for other reasons (e.g. applying interest).
      allow update: if isFinance() || isSuperAdmin();

      // Only Super Admin can create or delete portfolios.
      allow create, delete: if isSuperAdmin();
    }
  }
}
