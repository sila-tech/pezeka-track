
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a Role-Based Access Control (RBAC) model.
     * We prioritize domain-based authorization for Pezeka staff.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Robust check for Finance authorization. 
     */
    function isFinance() {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      // Explicitly grant Simon access by email and known UIDs immediately
      let isSimon = email == 'simon@pezeka.com' || email == 'simon@finance.pezeka.com' || uid == 'Z8gkNLZEVUWbsooR8R7OuHxApB62' || uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2';
      
      if (isSimon) return true;
      
      let isFinanceDomain = email != null && email.endsWith('@finance.pezeka.com');
      
      // Check role only if Simon/Domain check fails
      return isSignedIn() && (isFinanceDomain || (exists(/databases/$(database)/documents/users/$(uid)) && get(/databases/$(database)/documents/users/$(uid)).data.role.lower() == 'finance'));
    }

    /** 
     * @description Robust check for Staff authorization. 
     */
    function isStaff() {
      let email = request.auth.token.email;
      let uid = request.auth.uid;
      
      let isSimon = email == 'simon@pezeka.com' || uid == 'Z8gkNLZEVUWbsooR8R7OuHxApB62' || uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2';
      
      if (isSimon) return true;
      
      let isStaffDomain = email != null && (email.endsWith('@staff.pezeka.com') || email.endsWith('@finance.pezeka.com'));
      
      return isSignedIn() && (isStaffDomain || (exists(/databases/$(database)/documents/users/$(uid)) && get(/databases/$(database)/documents/users/$(uid)).data.role.lower() in ['staff', 'finance']));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isFinance();
      allow delete: if isFinance();
    }

    match /expenseRequests/{requestId} {
      allow get: if isStaff() && (resource.data.staffId == request.auth.uid || isFinance());
      allow list: if isStaff();
      allow create: if isStaff() && request.resource.data.staffId == request.auth.uid;
      allow update: if isFinance();
      allow delete: if isFinance();
    }

    match /customers/{customerId} {
      allow get, list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isSignedIn();
      allow update: if isStaff() || isOwner(customerId);
      allow delete: if isFinance();
    }

    match /customers/{customerId}/loans/{loanId} {
      allow get, list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isOwner(customerId);
      allow update: if isStaff();
      allow delete: if isFinance();

      match /repayments/{repaymentId} {
        allow get, list: if isStaff() || isOwner(customerId);
        allow create: if isStaff();
        allow update: if isStaff();
        allow delete: if isFinance();
      }
    }

    match /loans/{loanId} {
      allow get, list: if isStaff() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isStaff() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isFinance();
    }

    match /kyc_documents/{docId} {
      allow get, list, create, update, delete: if isStaff();
    }

    match /dailyExpenses/{expenseId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyPayouts/{payoutId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyReceipts/{receiptId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /financeEntries/{entryId} {
      allow get, list, create, update, delete: if isFinance() || isStaff();
    }

    match /investors/{investorId} {
      allow get: if isSignedIn() && (request.auth.uid == investorId || isFinance());
      allow list, create, update, delete: if isFinance();
    }

    match /mail_logs/{logId} {
      allow get, list, create: if isFinance() || isStaff();
      allow update, delete: if false;
    }
  }
}
