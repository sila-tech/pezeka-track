rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the signed-in user is Simon.
     */
    function isSimon() {
      return isSignedIn() && request.auth.token.email == 'simon@pezeka.com';
    }
    
    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * All collections are only accessible by Simon.
     */
    match /{document=**} {
      allow read, write: if isSimon();
    }
  }
}
