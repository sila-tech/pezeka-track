rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a Role-Based Access Control (RBAC) model tailored for internal staff at Pezeka Credit Ltd. 
     * Access is partitioned between 'staff' and 'finance' roles.
     * 
     * DATA STRUCTURE
     * - /users/{userId}: Internal staff profiles containing the authoritative 'role' field.
     * - /customers/{customerId}: Global list of loan applicants/clients.
     * - /customers/.../loans/.../repayments: Hierarchical tree for financial tracking.
     * - /dailyExpenses, /dailyPayouts, /dailyReceipts: Top-level collections restricted to the finance role.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Retrieves the user document for the currently authenticated user safely. */
    function getAuthUser() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    /** @description Checks if the authenticated user has a specific role (case-insensitive). */
    function hasRole(role) {
      let user = getAuthUser();
      return isSignedIn() && user != null && 
             (user.role.lower() == role.lower());
    }

    /** @description Checks if the user is a recognized staff member via profile or verified domain. */
    function isStaff() {
      // Primary check: Firestore profile role
      if (hasRole('staff') || hasRole('finance')) {
        return true;
      }
      
      // Fallback check: Verified email domains for immediate access post-login
      let email = request.auth.token.email;
      return isSignedIn() && (
        email.endsWith('@staff.pezeka.com') || 
        email.endsWith('@finance.pezeka.com') || 
        email == 'simon@pezeka.com'
      );
    }

    /** @description Checks if the user is the owner of the document based on UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Staff profile management.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Customer records. Accessible to all internal staff.
     */
    match /customers/{customerId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    /**
     * @description Loan records nested under customers.
     */
    match /customers/{customerId}/loans/{loanId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.customerId == customerId;
      allow update: if isStaff();
      allow delete: if isStaff();

      match /repayments/{repaymentId} {
        allow get, list: if isStaff();
        allow create: if isStaff() && request.resource.data.loanId == loanId;
        allow update: if isStaff();
        allow delete: if isStaff();
      }
    }

    /**
     * @description Top level loans collection.
     */
    match /loans/{loanId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    /**
     * @description KYC Document Repository. 
     * Staff can upload (create), but only Finance/Admin can list and view.
     */
    match /kyc_documents/{docId} {
      allow create: if isStaff();
      allow get, list, update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    /**
     * @description Financial collections restricted to finance staff.
     */
    match /dailyExpenses/{expenseId} {
      allow get, list: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
      allow create: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
      allow update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    match /dailyPayouts/{payoutId} {
      allow get, list, create, update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    match /dailyReceipts/{receiptId} {
      allow get, list, create, update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    match /financeEntries/{entryId} {
      allow get, list, create, update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    match /investors/{investorId} {
      allow get: if isSignedIn() && (request.auth.uid == investorId || hasRole('finance') || request.auth.token.email == 'simon@pezeka.com');
      allow list, create, update, delete: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
    }

    match /mail_logs/{logId} {
      allow get, list, create: if hasRole('finance') || request.auth.token.email == 'simon@pezeka.com';
      allow update, delete: if false;
    }
  }
}