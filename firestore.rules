rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only finance users (including Simon) can read or write any document.
    function isFinanceUser() {
      return request.auth != null && (
        request.auth.token.email == 'simon@pezeka.com' ||
        request.auth.token.email.matches('.*@finance\\.pezeka\\.com$')
      );
    }

    match /{document=**} {
      allow read, write: if isFinanceUser();
    }
  }
}
