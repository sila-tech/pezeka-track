
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles by looking up their profile
    function isSuperAdmin() {
      return request.auth.token.email == 'simon@pezeka.com';
    }

    function getUserRole() {
      // A user's role is stored in their profile document in the 'users' collection.
      // This now safely returns an empty string if the document doesn't exist.
      if (exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      return '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isInvestorOwner(investorId) {
      return request.auth.uid == investorId;
    }

    // Rules for User Profiles
    match /users/{userId} {
      allow get: if isSuperAdmin();
      allow get: if isOwner(userId);
      allow list, write: if isSuperAdmin();
    }

    // Rules for Customers collection
    match /customers/{customerId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isStaff();
      allow read, write: if isFinance();
    }

    // Rules for Loans
    match /loans/{loanId} {
      // Write access
      allow write: if isSuperAdmin();
      allow write: if isStaff();
      allow write: if isFinance();
      
      // Read access
      allow read: if isSuperAdmin();
      allow read: if isStaff();
      allow read: if isFinance();
      
      // CUSTOMER-specific rules (for non-admins)
      allow get: if request.auth.uid == resource.data.customerId;
      allow list: if request.auth.uid == request.resource.data.customerId;
      allow create: if request.auth.uid == request.resource.data.customerId && request.resource.data.status == 'application';
    }
    
    // Rules for Finance Entries
    match /financeEntries/{entryId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isFinance();
    }

    // Rules for Investors
    match /investors/{investorId} {
      // Allow any authenticated user to read. The UI controls which roles can access the investors page.
      // This is necessary because Firestore rules for queries ('list') cannot perform document lookups.
      allow read: if request.auth != null;

      // Allow only the superAdmin to create new investor profiles.
      allow create: if isSuperAdmin();

      // Allow superAdmin and finance to update. These are separated to avoid evaluation errors.
      allow update: if isSuperAdmin();
      allow update: if isFinance();
      
      // Allow only superAdmin to delete.
      allow delete: if isSuperAdmin();
    }

  }
}
