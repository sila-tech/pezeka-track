
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles by looking up their profile
    function isSuperAdmin() {
      return request.auth.token.email == 'simon@pezeka.com';
    }

    function getUserRole() {
      // A user's role is stored in their profile document in the 'users' collection.
      // This now safely returns an empty string if the document doesn't exist.
      if (exists(/databases/$(database)/documents/users/$(request.auth.uid))) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      return '';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isFinance() {
      return getUserRole() == 'finance';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for User Profiles
    match /users/{userId} {
      allow get: if isSuperAdmin() || isOwner(userId);
      allow list, write: if isSuperAdmin();
    }

    // Rules for Customers collection
    match /customers/{customerId} {
      allow list: if request.auth != null; 
      allow get, write: if isSuperAdmin() || isStaff() || isFinance(); 
    }

    // Rules for Loans
    match /loans/{loanId} {
      allow list: if request.auth != null;
      allow get: if request.auth.uid == resource.data.customerId || isSuperAdmin() || isStaff() || isFinance();
      allow write: if isSuperAdmin() || isStaff() || isFinance();
      allow create: if request.auth.uid == request.resource.data.customerId && request.resource.data.status == 'application';
    }
    
    // Rules for Finance Entries
    match /financeEntries/{entryId} {
      allow list: if request.auth != null;
      allow get, write: if isSuperAdmin() || isFinance();
    }

    // Rules for Investors collection
    match /investors/{investorId} {
      // Allow admins to list all investors for the dashboard
      allow list: if isSuperAdmin() || isFinance() || isStaff();
      // Allow an investor to read their own document, and admins to read any
      allow get: if isOwner(investorId) || isSuperAdmin() || isFinance() || isStaff();
      // Allow super admin to create/delete, and finance/superadmin to update
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isFinance();
    }
  }
}
