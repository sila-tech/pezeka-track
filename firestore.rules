rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('email', '').lower() == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Safely check for a specific role in the user's profile document
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Finance and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Simplified validation for loan applications
    function isValidCustomerApplication() {
      return isAuthenticated() && 
             request.resource.data.get('customerId', '') == request.auth.uid &&
             request.resource.data.get('status', '').lower() == 'application';
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /users/{userId} {
      allow get: if isStaff() || isOwner(userId);
      allow list: if isStaff();
      allow write: if isSuperAdmin() || isOwner(userId);
    }

    match /customers/{customerId} {
      allow get: if isStaff() || isOwner(customerId);
      allow list: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isOwner(customerId) || isAuthenticated();
      allow update: if isFinance() || isOwner(customerId);
      allow delete: if isFinance();
    }

    match /loans/{loanId} {
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      allow create: if isFinance() || isValidCustomerApplication();
      allow update: if isFinance() || (isStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followUpNotes', 'updatedAt']));
      allow delete: if isFinance();
    }

    match /financeEntries/{entryId} {
      allow read: if isStaff();
      allow write: if isFinance();
    }

    match /mail_logs/{logId} {
      allow read: if isFinance();
      allow write: if isAuthenticated();
    }

    match /investors/{investorId} {
      allow read: if isFinance() || isOwner(investorId);
      allow write: if isFinance();
    }

    match /system_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
