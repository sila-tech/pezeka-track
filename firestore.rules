rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a Role-Based Access Control (RBAC) model tailored for internal staff at Pezeka Credit Ltd. 
     * Access is partitioned between 'staff' and 'finance' roles.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Retrieves the user document path for the current user. */
    function authUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    /** @description Checks if the authenticated user has a specific role (case-insensitive). */
    function hasRole(role) {
      return isSignedIn() && 
             exists(authUserPath()) && 
             get(authUserPath()).data.role.lower() == role.lower();
    }

    /** @description Checks if the user is a recognized staff member via profile or verified domain. */
    function isStaff() {
      return isSignedIn() && (
        hasRole('staff') || 
        hasRole('finance') ||
        (request.auth.token.email != null && (
          request.auth.token.email.endsWith('@staff.pezeka.com') || 
          request.auth.token.email.endsWith('@finance.pezeka.com') || 
          request.auth.token.email == 'simon@pezeka.com'
        ))
      );
    }

    /** @description Checks if the user is the owner of the document based on UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user has finance level access. */
    function isFinance() {
      return isSignedIn() && (
        hasRole('finance') || 
        (request.auth.token.email != null && (
          request.auth.token.email.endsWith('@finance.pezeka.com') || 
          request.auth.token.email == 'simon@pezeka.com'
        ))
      );
    }

    // --- Collection Rules ---

    /**
     * @description Staff profile management.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Customer records. Accessible to all internal staff.
     */
    match /customers/{customerId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    /**
     * @description Loan records nested under customers.
     */
    match /customers/{customerId}/loans/{loanId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.customerId == customerId;
      allow update: if isStaff();
      allow delete: if isStaff();

      match /repayments/{repaymentId} {
        allow get, list: if isStaff();
        allow create: if isStaff() && request.resource.data.loanId == loanId;
        allow update: if isStaff();
        allow delete: if isStaff();
      }
    }

    /**
     * @description Top level loans collection for aggregate queries.
     */
    match /loans/{loanId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isFinance();
    }

    /**
     * @description KYC Document Repository. 
     * Staff can upload (create), but only Finance/Admin can list and view.
     */
    match /kyc_documents/{docId} {
      allow create: if isStaff();
      allow get, list, update, delete: if isFinance();
    }

    /**
     * @description Financial collections restricted to finance staff.
     */
    match /dailyExpenses/{expenseId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyPayouts/{payoutId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /dailyReceipts/{receiptId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /financeEntries/{entryId} {
      allow get, list, create, update, delete: if isFinance();
    }

    match /investors/{investorId} {
      allow get: if isSignedIn() && (request.auth.uid == investorId || isFinance());
      allow list, create, update, delete: if isFinance();
    }

    match /mail_logs/{logId} {
      allow get, list, create: if isFinance();
      allow update, delete: if false;
    }
  }
}