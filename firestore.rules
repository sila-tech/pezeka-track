rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Safely check for a specific role in the user's profile document
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Simon, Finance, and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only Simon, Finance, or the Owner can modify profiles
      allow write: if isSuperAdmin() || isFinance() || isOwner(userId);
    }

    // Customers
    match /customers/{customerId} {
      // Customers manage their own record; Staff/Finance manage all
      allow read, write: if isStaff() || isOwner(customerId);
    }

    // Loans
    match /loans/{loanId} {
      // Read: Staff/Finance see all. Customers see only their own loans.
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      
      // Create: Allowed for any authenticated user (to support applications from Android and Web)
      allow create: if isAuthenticated();
      
      // Update/Delete: Staff/Finance manage all. Customers can only update their own applications.
      allow update, delete: if isStaff() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
    }

    // Finance Entries
    match /financeEntries/{entryId} {
      // STRICT: ONLY Simon and Finance users can access or edit the financial ledger
      // Staff members and customers are strictly denied
      allow read, write: if isFinance();
    }

    // Investors
    match /investors/{investorId} {
      // Investors can view their own portfolios; Finance/Simon manage all
      allow read: if isFinance() || isOwner(investorId);
      allow write: if isFinance();
    }
  }
}