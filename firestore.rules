rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the Super Admin (Simon)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.get('email', '').lower() == 'simon@pezeka.com' || 
        request.auth.uid == 'gHZ9n7s2b9X8fJ2kP3s5t8YxVOE2'
      );
    }

    // Safely check for a specific role in the user's profile document
    function hasRole(roleName) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == roleName;
    }

    // Finance Role: Includes Simon and designated Finance users
    function isFinance() {
      return isSuperAdmin() || hasRole('finance');
    }

    // Staff Role: Includes Finance and designated Staff users
    function isStaff() {
      return isFinance() || hasRole('staff');
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Shared validation for loan applications (Customer Side)
    // Updated to allow all fields sent by the app's internal submission logic
    // while strictly enforcing the 'application' status.
    function isValidCustomerApplication() {
      let allowedFields = [
        'amount', 'principalAmount', 'tenureMonths', 'idNumber', 'nextOfKinName', 
        'nextOfKinPhone', 'paymentMethod', 'accountNumber', 
        'customerId', 'status', 'createdAt', 'loanType', 'customerName', 
        'customerPhone', 'alternativeNumber', 'paymentFrequency', 'numberOfInstalments',
        'comments', 'loanNumber', 'interestRate', 'registrationFee', 'processingFee',
        'carTrackInstallationFee', 'chargingCost', 'instalmentAmount', 'totalRepayableAmount',
        'totalPaid', 'totalPenalties', 'disbursementDate', 'payments', 'penalties',
        'followUpNotes', 'disbursementRecorded', 'updatedAt'
      ];
      return isAuthenticated() && 
             request.resource.data.customerId == request.auth.uid &&
             request.resource.data.status == 'application' &&
             request.resource.data.keys().hasOnly(allowedFields);
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    // User Profiles (Admin Staff/Finance)
    match /users/{userId} {
      allow read: if isStaff();
      allow write: if isSuperAdmin();
    }

    // Customers
    match /customers/{customerId} {
      allow read: if isStaff() || isOwner(customerId);
      allow create: if isStaff() || isOwner(customerId);
      allow update: if isFinance() || isOwner(customerId);
      allow delete: if isFinance();
    }

    // Loans
    match /loans/{loanId} {
      // Read: Staff/Finance see all. Customers see only their own.
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      
      // Create: Finance/Admin can add direct records. Customers use application schema.
      allow create: if isFinance() || isValidCustomerApplication();
      
      // Update: Finance manages all. Staff can ONLY add followUpNotes.
      allow update: if isFinance() || (
        isStaff() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followUpNotes', 'updatedAt'])
      );

      // Delete: Strictly Finance/Admin
      allow delete: if isFinance();
    }

    // Loan Applications (Mirrors the loans collection policy)
    match /loan_applications/{appId} {
      allow read: if isStaff() || (isAuthenticated() && (resource == null || resource.data.customerId == request.auth.uid));
      allow create: if isFinance() || isValidCustomerApplication();
      allow update, delete: if isFinance();
    }

    // Finance Entries (Sensitive Ledger)
    match /financeEntries/{entryId} {
      allow read, write: if isFinance();
    }

    // Investors
    match /investors/{investorId} {
      allow read: if isFinance() || isOwner(investorId);
      allow write: if isFinance();
    }
  }
}
